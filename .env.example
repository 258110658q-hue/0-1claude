# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# API 密钥（必填）
ANTHROPIC_API_KEY=你的API密钥

# 模型 ID（必填）
# Claude 系列: claude-sonnet-4-6 / claude-opus-4-8 / claude-haiku-4-5
# 其他兼容模型: deepseek-chat
MODEL_ID=claude-sonnet-4-6

# 自定义 API 地址（可选，使用 DeepSeek 或中转平台时填写）
# ANTHROPIC_BASE_URL=https://api.deepseek.com

# 备用模型（可选，连续 529 过载后自动切换）
# FALLBACK_MODEL_ID=deepseek-chat
